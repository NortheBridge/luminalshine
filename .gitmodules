# Linux Flatpak packaging deps. LuminalShine is Windows-only by design;
# the ci-linux.yml / ci-archlinux.yml / ci-flatpak.yml workflows that
# would have needed these are unreferenced (no caller). Commented out
# (not removed) so a future Linux-revival can flip them back on by
# uncommenting the block and re-running `git submodule add` against
# the same URL.
#[submodule "packaging/linux/flatpak/deps/flatpak-builder-tools"]
#	path = packaging/linux/flatpak/deps/flatpak-builder-tools
#	url = https://github.com/flatpak/flatpak-builder-tools.git
#	branch = master
#[submodule "packaging/linux/flatpak/deps/shared-modules"]
#	path = packaging/linux/flatpak/deps/shared-modules
#	url = https://github.com/flathub/shared-modules.git
#	branch = master
[submodule "third-party/build-deps"]
	path = third-party/build-deps
	url = https://github.com/LizardByte/build-deps.git
	branch = master
# doxyconfig is not OS-specific, but the pinned commit
# `89c8ec928a11e04a75f06a00ddaa3848fc5edf27` no longer exists on the
# public LizardByte/doxyconfig remote (force-pushed or the repo was
# made private), so `git submodule update` fails the entire checkout
# with "Direct fetching of that commit failed" + an interactive
# Username prompt git can't satisfy on the CI runner. Windows CI sets
# -DBUILD_DOCS=OFF in both ci-windows.yml and coverage-windows.yml so
# the `add_subdirectory(third-party/doxyconfig)` block in
# cmake/targets/common.cmake is skipped — the submodule's contents
# are not consumed by the Windows binary build. Uncomment and update
# the pin via the upstream LizardByte org's docs-publishing workflow
# when docs generation needs to come back.
#[submodule "third-party/doxyconfig"]
#	path = third-party/doxyconfig
#	url = https://github.com/LizardByte/doxyconfig.git
#	branch = master
[submodule "third-party/googletest"]
	path = third-party/googletest
	url = https://github.com/google/googletest.git
	branch = main
# Linux input emulation library. Used only by
# src/platform/linux/input/inputtino_*.cpp, which the
# cmake/compile_definitions/linux.cmake conditional only compiles on
# Linux. Commented out for the Windows-only scope; flip back on if
# Linux support returns.
#[submodule "third-party/inputtino"]
#	path = third-party/inputtino
#	url = https://github.com/games-on-whales/inputtino.git
#	branch = stable
[submodule "third-party/libdisplaydevice"]
	path = third-party/libdisplaydevice
	url = https://github.com/Nonary/libdisplaydevice.git
	branch = display_rework_v2
[submodule "third-party/moonlight-common-c"]
	path = third-party/moonlight-common-c
	url = https://github.com/moonlight-stream/moonlight-common-c.git
	branch = master
[submodule "third-party/nanors"]
	path = third-party/nanors
	url = https://github.com/sleepybishop/nanors.git
	branch = master
[submodule "third-party/nv-codec-headers"]
	path = third-party/nv-codec-headers
	url = https://github.com/FFmpeg/nv-codec-headers.git
	branch = master
[submodule "third-party/nvapi-open-source-sdk"]
	path = third-party/nvapi-open-source-sdk
	url = https://github.com/Nonary/nvapi.git
	branch = main
[submodule "third-party/Simple-Web-Server"]
	path = third-party/Simple-Web-Server
	url = https://github.com/LizardByte-infrastructure/Simple-Web-Server.git
	branch = master
[submodule "third-party/TPCircularBuffer"]
	path = third-party/TPCircularBuffer
	url = https://github.com/michaeltyson/TPCircularBuffer.git
	branch = master
[submodule "third-party/ViGEmClient"]
	path = third-party/ViGEmClient
	url = https://github.com/LizardByte/Virtual-Gamepad-Emulation-Client.git
	branch = master
[submodule "third-party/tray"]
	path = third-party/tray
	url = https://github.com/Nonary/tray
	branch = master
[submodule "third-party/libwebrtc"]
	path = third-party/libwebrtc
	url = https://github.com/Nonary/libwebrtc
	branch = feat/upgrade-to-m137
[submodule "third-party/depot_tools"]
	path = third-party/depot_tools
	url = https://chromium.googlesource.com/chromium/tools/depot_tools.git
[submodule "winget-pkgs"]
	path = winget-pkgs
	url = https://github.com/microsoft/winget-pkgs.git
