# docs/Doxyfile-xml — XML-only override consumed by breathe.
#
# Inherits the project metadata from the main Doxyfile, then forces
# XML output and restricts INPUT to the C++ source tree. Markdown
# files are rendered by Sphinx directly (myst-parser), so we don't
# want Doxygen to also process them.

@INCLUDE = Doxyfile

# Output formats
GENERATE_HTML        = NO
GENERATE_LATEX       = NO
GENERATE_XML         = YES
XML_OUTPUT           = _doxygen/xml
XML_PROGRAMLISTING   = YES

# Index only the C++ source tree — Sphinx owns the prose docs now.
# Overrides the INPUT list from the inherited Doxyfile, including the
# `../third-party/doxyconfig/docs/source_code.md` reference that no
# longer resolves (the doxyconfig submodule is disabled in .gitmodules).
INPUT                = ../src
RECURSIVE            = YES
FILE_PATTERNS        = *.h *.hpp *.hh *.hxx *.c *.cpp *.cc *.cxx

# Breathe's C++ domain doesn't model Objective-C `@property` /
# `@interface`, so excluding the macOS platform tree avoids hard
# crashes during Sphinx rendering. The standalone Doxygen HTML (when
# rebuilt) is unaffected; only the XML-for-breathe pass skips ObjC.
EXCLUDE              = ../src/platform/macos

# Quiet noise; breathe failures will surface in Sphinx output anyway.
QUIET                = YES
WARN_LOGFILE         = _doxygen/doxygen-warnings.log

# Skip diagram generation for the XML pass — graphs only matter for the
# (no longer produced) standalone HTML browser.
HAVE_DOT             = NO
