<?xml version="1.0" encoding="UTF-8"?>
<!--
  luminalshine.wxs — top-level WiX 7 (schema v4) product authoring for
  the hand-authored MSI build.

  Schema-level changes vs the prior WiX 3 file (PR3 of the migration):

    * Namespace bumped to http://wixtoolset.org/schemas/v4/wxs (the v4
      schema covers WiX 4 through WiX 7 — no separate "v7" namespace
      exists).
    * <Product> is gone; its content moved onto <Package> at the root
      with merged attributes. The old inner <Package InstallerVersion=
      Compressed="yes"/> attributes hang off the root <Package> now.
    * TARGETDIR is implicit; standard directories
      (ProgramFiles64Folder, ProgramMenuFolder) are wrapped in
      <StandardDirectory> instead of nested under TARGETDIR.
    * <Condition Message="...">expr</Condition> (the top-level Privileged
      launch condition) became <Launch Condition="expr" Message="..."/>.
    * <Custom Action="X" After="Y">expr</Custom> (condition as element
      text) became <Custom Action="X" After="Y" Condition="expr"/>
      (condition as attribute). Operator whitespace is preserved verbatim
      to match the golden — see the InstallExecuteSequence comments
      below for the reasoning history.
    * <Feature Absent="disallow"/> became <Feature AllowAbsent="no"/>
      (inverse YesNo encoding). Still compiles to Attributes=16.
    * <Component Win64="yes"/> became <Component Bitness="always64"/>.
      Same for RegistrySearch.
    * <UIRef Id="WixUI_FeatureTree"/> became <ui:WixUI Id="..."/> from
      the ui extension namespace. The WixUI_ErrorProgressText pull-in
      is implicit in v4's WixUI_FeatureTree and no longer needs its
      own reference.

  Cross-fragment references that DID NOT change:

    * INSTALL_ROOT, INSTALL_PREFIX_1, LUMINALSHINE_PROGRAM_MENU_FOLDER
      directory IDs.
    * ProductFeature / CM_G_* / CM_C_* feature hierarchy (still emitted
      by scripts/gen_wix_files.py into wix_gen/features.wxs).
    * LuminalShineExtras feature membership: ComponentRefs of the
      hand-authored Components defined in custom_actions.wxs.
    * The custom-action IDs in the InstallExecuteSequence /
      InstallUISequence blocks. Conditions preserved verbatim (the
      scripts/lint_wix_conditions.py lint enforces them in CI).
    * All -d preprocessor variable bindings — the CMake driver passes
      ProductCode, ProductName, ProductVersion, Manufacturer,
      UpgradeCode, LuminalShineAppId, LicenseRtf, ProductIcon through
      to `wix build` via -d flags exactly as it did to candle.

  Bootstrapper invariant (unchanged across the entire migration):
  LuminalShineSetup.exe / uninstall.exe (the C# / Roslyn binaries
  with the embedded Payload.msi resource) consume the MSI as
  produced; nothing in this file changes the bootstrapper-MSI
  property contract (INSTALL_ROOT, INSTALL_MTTVDD, INSTALL_SUDOVDA,
  KEEPADMINCREDENTIALS, KEEPSESSIONDATA, REMOVEVIRTUALDISPLAYDRIVER,
  DELETEINSTALLDIR, SKIP_REMOVE_CONFLICTING_PRODUCTS).
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:firewall="http://wixtoolset.org/schemas/v4/wxs/firewall"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <!--
    The product identity. Preprocessor variables are bound via
    `wix build -d Name=Value` in the CMake driver:
      ProductCode      — fresh UUID per build (matches CPack's per-build
                         ProductCode generation; the table differ
                         normalizes ProductCode away so the value need
                         not be stable across builds).
      ProductName      — LuminalShine
      ProductVersion   — sanitized x.x.x.x derived from PROJECT_VERSION
      Manufacturer     — NortheBridge Foundation
      UpgradeCode      — fixed {C2C36624-2D9C-4AFD-9C79-6B7861AE4A0D}
                         (matches the golden; do not change or upgrades
                         will side-by-side instead of replacing).
      LuminalShineAppId, LicenseRtf, ProductIcon, PayloadRoot, MyScripts
                       — paths threaded through for icon / license /
                         binary resolution by `wix build`.
  -->
  <Package ProductCode="$(var.ProductCode)"
           Name="$(var.ProductName)"
           Language="1033"
           Version="$(var.ProductVersion)"
           Manufacturer="$(var.Manufacturer)"
           UpgradeCode="$(var.UpgradeCode)"
           InstallerVersion="301"
           Compressed="yes"
           Scope="perMachine">

    <!-- Scope="perMachine" replaces the WiX 3 idiom of explicit
         <Property Id="ALLUSERS" Value="1"/>. In WiX 4+ that property is
         emitted automatically when Scope="perMachine" so we do NOT
         re-declare it below — the v3 file did, but v4 errors with
         duplicate-symbol if both are present. Per-machine semantics
         are unchanged; the Privileged launch condition still enforces
         that an administrator is running msiexec. -->

    <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" />

    <!--
      Major upgrade scheduling — preserved verbatim from the WiX 3
      authoring. Schedule="afterInstallValidate" lets the
      KillProcsQuietImmediate / StopSvcQuietImmediate custom actions
      run on the new MSI's main transaction BEFORE
      RemoveExistingProducts hands off to the old MSI's nested
      uninstall. See the WIX_UPGRADE_DETECTED block in the
      InstallExecuteSequence below for the upgrade-pass coverage
      that depends on this ordering.
    -->
    <MajorUpgrade Schedule="afterInstallValidate"
                  AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A later version of [ProductName] is already installed. Setup will now exit." />

    <!-- WixUI binding — keep WixUI_FeatureTree from the WiX 3 file.
         WiX 4+ accesses it via the ui extension's <ui:WixUI/> element;
         the prior <UIRef Id="WixUI_FeatureTree"/> + <UIRef
         Id="WixUI_ErrorProgressText"/> pair collapses to a single
         <ui:WixUI Id="WixUI_FeatureTree"/> because the error/progress
         dialog is bundled with FeatureTree in v4. WIXUI_INSTALLDIR is
         kept so any WixUI dialog that does ask for an install location
         still resolves to INSTALL_ROOT.

         ARP* properties (ARPCOMMENTS, ARPCONTACT, ARPURLINFOABOUT)
         set Add/Remove Programs metadata, matching the prior
         CPACK_WIX_PROPERTY_ARP* defaults. -->
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALL_ROOT" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon.ico" />
    <Property Id="ARPCOMMENTS" Value="Modern Self-hosted game stream host for Moonlight" />
    <Property Id="ARPCONTACT" Value="https://github.com/NortheBridge/luminalshine/issues" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/NortheBridge/luminalshine" />
    <Icon Id="ProductIcon.ico" SourceFile="$(var.ProductIcon)" />

    <ui:WixUI Id="WixUI_FeatureTree" />

    <!-- ARPINSTALLLOCATION = the install path that Add/Remove Programs
         shows for the product. CPack-WIX auto-emitted this Type-51
         SetProperty CustomAction + sequence entries; doing the same
         here matches the golden's CustomAction row
         (Source=ARPINSTALLLOCATION, Target=[INSTALL_ROOT]) and the
         InstallExecuteSequence/InstallUISequence positions (10 / 16
         respectively).

         An earlier draft used <SetProperty Sequence="both"
         After="InstallValidate"> as a one-liner. That failed at light
         with LGHT0094 ("Unresolved reference to symbol
         WixAction:InstallUISequence/InstallValidate") because
         InstallValidate is a standard action of
         InstallExecuteSequence only, not InstallUISequence. The
         schedule anchors are sequence-specific. Splitting into an
         explicit <CustomAction> + two <Custom> entries with
         per-sequence anchors gives both sequences a valid reference:
         After="InstallValidate" for execute, After="CostFinalize"
         for UI (CostFinalize exists in both, but matching CPack-WIX's
         observed UISequence position 16 specifically). -->
    <CustomAction Id="SetARPINSTALLLOCATION"
                  Property="ARPINSTALLLOCATION"
                  Value="[INSTALL_ROOT]" />

    <!-- Mark INSTALL_ROOT as a Secure property so msiexec accepts it
         as a command-line override on a per-machine install. WiX
         compiles all <Property Id="X" Secure="yes"/> declarations into
         the MSI's SecureCustomProperties summary entry. INSTALL_ROOT
         is both a Directory id and (at runtime) a public property
         whose value is the resolved install path; WiX 4+ accepts a
         <Property> with the same Id to mark the property side. The
         golden's SecureCustomProperties value confirms CPack-WIX did
         the equivalent. -->
    <Property Id="INSTALL_ROOT" Secure="yes" />

    <!--
      ===========================================================
      Properties folded from patch_custom_actions.wxs
      ===========================================================
      Scope="perMachine" on <Package> implicitly sets ALLUSERS=1
      so the legacy explicit Property is omitted. The Privileged
      launch condition (below, as <Launch/>) keeps this firmly a
      per-machine install — matched by the requireAdministrator
      manifest on the bootstrapper. Any drift here breaks the
      Reset Admin shortcut's HKCU keypath ICE38/43 compliance
      that's already been hard-won (commits 92c30771 / fe6c73a4).
    -->
    <Property Id="ARPSYSTEMCOMPONENT" Value="1" />

    <Property Id="LEGACY_SUNSHINE_PRESENT" Secure="yes">
      <RegistrySearch Id="SearchLegacySunshine64" Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\Sunshine" Name="DisplayName" Type="raw" Bitness="always64" />
      <RegistrySearch Id="SearchLegacySunshine32" Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\Sunshine" Name="DisplayName" Type="raw" Bitness="always32" />
    </Property>
    <Property Id="LEGACY_SUNSHINE_UNINSTALL" Secure="yes">
      <RegistrySearch Id="SearchLegacySunshineUninstall64" Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\Sunshine" Name="UninstallString" Type="raw" Bitness="always64" />
      <RegistrySearch Id="SearchLegacySunshineUninstall32" Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\Sunshine" Name="UninstallString" Type="raw" Bitness="always32" />
    </Property>

    <!-- Bootstrapper-contract MSI properties. The bootstrapper passes
         INSTALL_MTTVDD / INSTALL_SUDOVDA / REMOVEVIRTUALDISPLAYDRIVER
         / SKIP_REMOVE_CONFLICTING_PRODUCTS / KEEPADMINCREDENTIALS /
         KEEPSESSIONDATA / DELETEINSTALLDIR on the msiexec command line
         (see RunInstallAttempt in LuminalShineInstaller.cs). Defaults
         here are the values used when the property is unset; the
         bootstrapper overrides per user choice. -->
    <Property Id="REMOVEVIRTUALDISPLAYDRIVER" Value="0" Secure="yes" />
    <Property Id="INSTALL_SUDOVDA" Value="1" Secure="yes" />
    <Property Id="INSTALL_MTTVDD" Value="0" Secure="yes" />
    <Property Id="SKIP_REMOVE_CONFLICTING_PRODUCTS" Value="0" Secure="yes" />

    <Launch Condition="Privileged" Message="Administrator privileges are required." />

    <!--
      ===========================================================
      Directory hierarchy — INSTALL_ROOT chain
      ===========================================================
      Matches what CPack auto-generated from
      CPACK_PACKAGE_INSTALL_DIRECTORY="NortheBridge\LuminalShine":
        ProgramFiles64Folder
          INSTALL_PREFIX_1 (Name=NortheBridge)
            INSTALL_ROOT   (Name=LuminalShine)

      In WiX 4+ the implicit TARGETDIR/SourceDir wrapper is gone and
      ProgramFiles64Folder is referenced via <StandardDirectory/>
      instead of being nested under <Directory Id="TARGETDIR"/>.
      The DefaultDir 8.3 short names in the golden (edtms2sm /
      r0ubect3) are auto-generated by WiX from the long names; using
      the same long names here reproduces them deterministically.

      ProgramMenuFolder + LUMINALSHINE_PROGRAM_MENU_FOLDER are
      declared by custom_actions.wxs, which extends the standard
      ProgramMenuFolder via its own StandardDirectoryRef. Do NOT
      re-declare them here.
    -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALL_PREFIX_1" Name="NortheBridge">
        <Directory Id="INSTALL_ROOT" Name="LuminalShine" />
      </Directory>
    </StandardDirectory>

    <!--
      ===========================================================
      Feature hierarchy
      ===========================================================
      The ProductFeature root + per-install-component CM_C_* and
      per-group CM_G_* features are emitted by gen_wix_files.py
      into <build>/wix_gen/features.wxs from
      packaging/windows/wix/features.json. We pull them in here
      via a single FeatureRef — actually just leave the
      cross-fragment Feature definitions to be linked by `wix build`,
      which traces ComponentRef back to its containing Feature
      automatically.

      The LuminalShineExtras feature stays hand-authored here
      because its ComponentRefs target hand-authored Components
      from custom_actions.wxs that are out of the auto-generator's
      scope (services, shortcuts, env, firewall, ARP, sudovda regs).
    -->
    <FeatureRef Id="ProductFeature" />

    <Feature Id="LuminalShineExtras" Title="LuminalShine Components" Level="1" AllowAbsent="no">
      <ComponentRef Id="CtlStopSunshine" />
      <ComponentRef Id="SunshineSvc" />
      <ComponentRef Id="LuminalShineXboxBtHelperSvc" />
      <ComponentRef Id="LuminalShineSessionMonSvc" />
      <ComponentRef Id="Env_Path" />
      <ComponentRef Id="Fw_Exceptions" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="ReconfigureStartMenuShortcut" />
      <ComponentRef Id="ResetAdminStartMenuShortcut" />
      <ComponentRef Id="SudoVdaRegistryDefaults" />
      <ComponentRef Id="ArpCustomUninstallEntry" />
    </Feature>

    <!--
      Feature-level Conditions for the virtual-display drivers live in
      packaging/windows/wix/features.json (each component spec carries
      an optional `conditions` field). The generator (gen_wix_files.py)
      writes them as <Level Value="N" Condition="expression"/> children
      of the corresponding <Feature> in features.wxs (the v4 form;
      WiX 3 used <Condition Level="N">expression</Condition>).

      An earlier draft tried to add them here via
      <FeatureRef Id="CM_C_mttvdd"><Condition>...</Condition></FeatureRef>
      to mirror the CPackWiXFragment patch mechanism — WiX 3.14's
      candle rejected that with CNDL0005. WiX 4+'s <Level/> element
      can only sit inside <Feature/>, so the placement decision is the
      same: emit it from the generator into the feature it gates.
    -->

    <!--
      ===========================================================
      InstallExecuteSequence — folded verbatim from the WiX 3
      authoring. The conditions and ordering are the production-
      load-bearing fix shipped in 9d590a6c — keep every clause
      exactly as-is. The lint scripts/lint_wix_conditions.py
      enforces these conditions in CI and will reject silent drift.

      WiX 4+ change: <Custom Action="X" After="Y">expr</Custom>
      (condition as element text) became
      <Custom Action="X" After="Y" Condition="expr"/> (condition
      as attribute). Operator whitespace inside the condition is
      preserved verbatim to match the golden — see the prior
      file's iter7-8 whitespace fix history.
      ===========================================================
    -->
    <InstallExecuteSequence>
      <!-- ARPINSTALLLOCATION setter. After="CostFinalize" puts it at
           Sequence=1001 (CostFinalize is the standard at 1000), which
           is the slot the golden uses — slot 10 in the normalized
           rank. After="InstallValidate" (the iter5 draft) put it at
           Sequence=1401 instead, which pushed it past
           MigrateFeatureStates (1200) and shifted the rank. -->
      <Custom Action="SetARPINSTALLLOCATION" After="CostFinalize" />

      <!-- Remove conflicting products before installation starts. -->
      <Custom Action="RemoveConflictingProducts" After="InstallInitialize" Condition="NOT Installed AND NOT REMOVE AND SKIP_REMOVE_CONFLICTING_PRODUCTS&lt;&gt;&quot;1&quot;" />

      <!-- Pre-validate stop/kill: fire across ALL UI levels (including the
           interactive full-UI install path). WIX_UPGRADE_DETECTED covers
           the install pass of a major upgrade — see the lengthy comment
           in patch_custom_actions.wxs (commit 9d590a6c) for why this
           condition shape is non-negotiable. -->
      <Custom Action="SetKillProcsQuietImmediate" Before="InstallValidate" Condition="WIX_UPGRADE_DETECTED OR (Installed AND NOT REMOVE) OR (REMOVE = &quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE)" />
      <Custom Action="KillProcsQuietImmediate" After="SetKillProcsQuietImmediate" Condition="WIX_UPGRADE_DETECTED OR (Installed AND NOT REMOVE) OR (REMOVE = &quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE)" />
      <Custom Action="SetStopSvcQuietImmediate" After="KillProcsQuietImmediate" Condition="WIX_UPGRADE_DETECTED OR (Installed AND NOT REMOVE) OR (REMOVE = &quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE)" />
      <Custom Action="StopSvcQuietImmediate" After="SetStopSvcQuietImmediate" Condition="WIX_UPGRADE_DETECTED OR (Installed AND NOT REMOVE) OR (REMOVE = &quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE)" />

      <!-- Deferred stop -->
      <Custom Action="SetStopSvcQuiet" After="InstallInitialize" Condition="WIX_UPGRADE_DETECTED OR (Installed AND NOT REMOVE) OR (REMOVE = &quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE)" />
      <Custom Action="StopSvcQuiet" After="SetStopSvcQuiet" Condition="WIX_UPGRADE_DETECTED OR (Installed AND NOT REMOVE) OR (REMOVE = &quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE)" />

      <!-- Start quietly on repair with basic/silent UI -->
      <Custom Action="SetStartSvcQuiet" Before="InstallFinalize" Condition="Installed AND NOT REMOVE AND UILevel&lt;5" />
      <Custom Action="StartSvcQuiet" Before="InstallFinalize" Condition="Installed AND NOT REMOVE AND UILevel&lt;5" />

      <!-- Manual uninstall: process/legacy service cleanup -->
      <Custom Action="SetKillProcsQuiet" After="StopSvcQuiet" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
      <Custom Action="KillProcsQuiet" After="SetKillProcsQuiet" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
      <Custom Action="SetRemoveServiceQuiet" After="KillProcsQuiet" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
      <Custom Action="RemoveServiceQuiet" After="SetRemoveServiceQuiet" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />

      <!-- Post-install chores -->
      <Custom Action="SetResetAcls" After="InstallFiles" Condition="NOT REMOVE" />
      <Custom Action="ResetAcls" After="SetResetAcls" Condition="NOT REMOVE" />
      <!-- Belt-and-suspenders: AND feature action state (=3 -> INSTALLSTATE_LOCAL)
           with the property switch so we never invoke install.ps1 against
           files that weren't staged, even if the feature condition above
           ever drifts out of sync with the INSTALL_* properties. -->
      <Custom Action="SetInstallMttVdd" After="ResetAcls" Condition="NOT REMOVE AND INSTALL_MTTVDD = &quot;1&quot; AND&amp;CM_C_mttvdd=3" />
      <Custom Action="InstallMttVdd" After="SetInstallMttVdd" Condition="NOT REMOVE AND INSTALL_MTTVDD = &quot;1&quot; AND&amp;CM_C_mttvdd=3" />
      <Custom Action="SetInstallSudovda" After="InstallMttVdd" Condition="NOT REMOVE AND INSTALL_SUDOVDA = &quot;1&quot; AND&amp;CM_C_sudovda=3" />
      <Custom Action="InstallSudovda" After="SetInstallSudovda" Condition="NOT REMOVE AND INSTALL_SUDOVDA = &quot;1&quot; AND&amp;CM_C_sudovda=3" />
      <Custom Action="SetMigrateConfig" After="InstallSudovda" Condition="NOT REMOVE" />
      <Custom Action="MigrateConfig" After="SetMigrateConfig" Condition="NOT REMOVE" />
      <Custom Action="SetRunInstallerMigrations" After="MigrateConfig" Condition="NOT REMOVE" />
      <Custom Action="RunInstallerMigrations" After="SetRunInstallerMigrations" Condition="NOT REMOVE" />

      <!-- Uninstall before file removal -->
      <Custom Action="SetRestoreNvPrefsUndo" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="RestoreNvPrefsUndo" After="SetRestoreNvPrefsUndo" Condition="REMOVE=&quot;ALL&quot;" />

      <!-- Clear admin credentials on a real uninstall (skipped during upgrades). -->
      <Custom Action="SetResetAdminCredentials" After="RestoreNvPrefsUndo" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE AND KEEPADMINCREDENTIALS&lt;&gt;&quot;1&quot;" />
      <Custom Action="ResetAdminCredentials" After="SetResetAdminCredentials" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE AND KEEPADMINCREDENTIALS&lt;&gt;&quot;1&quot;" />

      <!-- Wipe session telemetry on a real uninstall (skipped during upgrades). -->
      <Custom Action="SetResetSessionHistory" After="ResetAdminCredentials" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE AND KEEPSESSIONDATA&lt;&gt;&quot;1&quot;" />
      <Custom Action="ResetSessionHistory" After="SetResetSessionHistory" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE AND KEEPSESSIONDATA&lt;&gt;&quot;1&quot;" />

      <!-- Remove Virtual Display Drivers only when explicitly requested. -->
      <Custom Action="SetUninstallMttVdd" After="RestoreNvPrefsUndo" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE AND REMOVEVIRTUALDISPLAYDRIVER = &quot;1&quot;" />
      <Custom Action="UninstallMttVdd" After="SetUninstallMttVdd" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE AND REMOVEVIRTUALDISPLAYDRIVER = &quot;1&quot;" />
      <Custom Action="SetUninstallSudovda" After="UninstallMttVdd" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE AND REMOVEVIRTUALDISPLAYDRIVER = &quot;1&quot;" />
      <Custom Action="UninstallSudovda" After="SetUninstallSudovda" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE AND REMOVEVIRTUALDISPLAYDRIVER = &quot;1&quot;" />

      <!-- Execute delete/prune after MSI removes its files -->
      <Custom Action="SetDeleteInstallDir" After="RemoveFiles" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE AND DELETEINSTALLDIR = &quot;1&quot;" />
      <Custom Action="DeleteInstallDir" After="SetDeleteInstallDir" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE AND DELETEINSTALLDIR = &quot;1&quot;" />

      <!-- If not deleting whole dir, prune everything but config -->
      <Custom Action="SetPruneButConfig" After="RemoveFiles" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE AND DELETEINSTALLDIR&lt;&gt;&quot;1&quot;" />
      <Custom Action="PruneButConfig" After="SetPruneButConfig" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE AND DELETEINSTALLDIR&lt;&gt;&quot;1&quot;" />
    </InstallExecuteSequence>

    <!--
      InstallUISequence — legacy Sunshine pre-uninstall flow +
      repair-complete prompt. Folded verbatim.
    -->
    <!-- Note on condition whitespace: the golden's UILevel comparisons
         have NO surrounding spaces (e.g. UILevel>2 not UILevel > 2).
         Whatever the CPack-WIX path did normalized them out of the
         original "UILevel &gt; 2" source; this path doesn't, so match
         the golden by writing them without spaces directly. -->
    <InstallUISequence>
      <!-- ARPINSTALLLOCATION setter for the UI pass — scheduled at
           CostFinalize since InstallValidate doesn't exist in
           InstallUISequence. CostFinalize exists in both sequences. -->
      <Custom Action="SetARPINSTALLLOCATION" After="CostFinalize" />

      <Custom Action="AskUninstallLegacySunshine" After="AppSearch" Condition="LEGACY_SUNSHINE_PRESENT AND UILevel&gt;2 AND NOT Installed" />
      <Custom Action="WaitForLegacyUninstall" After="AskUninstallLegacySunshine" Condition="UNINSTALL_LEGACY_SUNSHINE = &quot;1&quot; AND NOT USER_CANCELLED_LEGACY_UNINSTALL" />
      <Custom Action="BlockUserCancelledLegacy" Before="LaunchConditions" Condition="USER_CANCELLED_LEGACY_UNINSTALL = &quot;1&quot;" />
      <Custom Action="BlockLegacySunshineStillPresent" Before="LaunchConditions" Condition="LEGACY_SUNSHINE_STILL_PRESENT = &quot;1&quot;" />
      <Custom Action="RepairCompletePrompt" After="ExecuteAction" Condition="REINSTALL AND NOT REMOVE AND NOT UPGRADINGPRODUCTCODE AND UILevel&gt;2" />
    </InstallUISequence>

  </Package>
</Wix>
