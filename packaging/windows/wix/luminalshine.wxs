<?xml version="1.0" encoding="UTF-8"?>
<!--
  luminalshine.wxs — top-level WiX 3 product authoring for the
  hand-authored (CPack-WIX-decoupled) MSI build introduced in
  PR2 of the WiX 7 migration.

  This file folds together two former inputs:
    * packaging/windows/wix/WIX.template.in — the CPack-WIX product
      template (Product, Package, Media, MajorUpgrade, WixVariable,
      WIXUI_INSTALLDIR, ARP icon, UIRef, FeatureRef ProductFeature).
    * packaging/windows/wix/patch_custom_actions.wxs — the
      CPackWiXPatch fragment (Properties, Privileged condition,
      LuminalShineExtras feature with hand-authored ComponentRefs,
      InstallExecuteSequence + InstallUISequence customizations,
      and the CM_C_mttvdd / CM_C_sudovda feature-level Conditions).

  The CPack-WIX-specific includes (cpack_variables.wxi,
  properties.wxi, product_fragment.wxi) and the CPackWiXFragment
  patch mechanism are gone — every value the includes provided is
  now passed to candle via -d preprocessor variables from the
  CMake driver (cmake/packaging/windows_wix.cmake).

  Cross-file references the build relies on:
    * Files/Directories/Components: emitted into <build>/wix_gen/
      files.wxs by scripts/gen_wix_files.py at build time.
    * Feature hierarchy (ProductFeature, CM_G_*, CM_C_*) and
      FeatureComponents bindings for auto-generated file Components:
      emitted into <build>/wix_gen/features.wxs by the same script.
    * Hand-authored Components for services, shortcuts, env, firewall,
      ARP, etc.: defined in packaging/windows/wix/custom_actions.wxs
      and pulled into the LuminalShineExtras feature below by Id.

  Bootstrapper invariant (unchanged across the entire migration):
  LuminalShineSetup.exe / uninstall.exe (the C# / Roslyn binaries
  with the embedded Payload.msi resource) consume the MSI as
  produced; nothing in this file changes the bootstrapper-MSI
  property contract (INSTALL_ROOT, INSTALL_MTTVDD, INSTALL_SUDOVDA,
  KEEPADMINCREDENTIALS, KEEPSESSIONDATA, REMOVEVIRTUALDISPLAYDRIVER,
  DELETEINSTALLDIR, SKIP_REMOVE_CONFLICTING_PRODUCTS).
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:Firewall="http://schemas.microsoft.com/wix/FirewallExtension"
     RequiredVersion="3.6.3303.0">

  <!--
    The product identity. Preprocessor variables are bound via candle -d
    in the CMake driver:
      ProductCode      — fresh UUID per build (matches CPack's per-build
                         ProductCode generation; the table differ
                         normalizes ProductCode away so the value need
                         not be stable across builds).
      ProductName      — LuminalShine
      ProductVersion   — sanitized x.x.x.x derived from PROJECT_VERSION
      Manufacturer     — NortheBridge Foundation
      UpgradeCode      — fixed {C2C36624-2D9C-4AFD-9C79-6B7861AE4A0D}
                         (matches the golden; do not change or upgrades
                         will side-by-side instead of replacing).
      LuminalShineAppId, LicenseRtf, ProductIcon, PayloadRoot, MyScripts
                       — paths threaded through for icon / license /
                         binary resolution by candle and light.
  -->
  <Product Id="$(var.ProductCode)"
           Name="$(var.ProductName)"
           Language="1033"
           Version="$(var.ProductVersion)"
           Manufacturer="$(var.Manufacturer)"
           UpgradeCode="$(var.UpgradeCode)">

    <!-- NOTE: no InstallScope= attribute. The combination of
         InstallScope="perMachine" + the explicit <Property Id="ALLUSERS"
         Value="1"/> below makes light fail with LGHT0091 ("Duplicate
         symbol Property:ALLUSERS"). InstallScope is a WiX 3 shortcut
         that auto-emits ALLUSERS=1; the explicit Property gives us more
         control and matches the CPack-WIX template's behavior (which
         set CPACK_WIX_INSTALL_SCOPE to "NONE" to disable the shortcut).
         Per-machine semantics are preserved end-to-end via ALLUSERS=1
         + the Privileged launch condition farther down. -->
    <Package InstallerVersion="301" Compressed="yes" />

    <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" />

    <!--
      Major upgrade scheduling — preserved verbatim from
      WIX.template.in. Schedule="afterInstallValidate" lets the
      KillProcsQuietImmediate / StopSvcQuietImmediate custom actions
      run on the new MSI's main transaction BEFORE
      RemoveExistingProducts hands off to the old MSI's nested
      uninstall. See the WIX_UPGRADE_DETECTED block in the
      InstallExecuteSequence below for the upgrade-pass coverage
      that depends on this ordering.
    -->
    <MajorUpgrade Schedule="afterInstallValidate"
                  AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A later version of [ProductName] is already installed. Setup will now exit." />

    <!-- WixUI binding — keep identical to the CPack-WIX product so the
         interactive installer's banner/dialog/license assets render
         the same as today.

         UIRef is WixUI_FeatureTree (NOT WixUI_InstallDir): CPack's
         CPACK_WIX_UI_REF default is FeatureTree, and the golden
         carries WixUI_Mode=FeatureTree. Using WixUI_InstallDir
         instead pulled in WixUIValidatePath as an extra CustomAction,
         set WixUI_Mode=InstallDir, and surfaced ARPNOMODIFY=1 — three
         table diffs vs the golden. FeatureTree avoids all of those.
         WIXUI_INSTALLDIR is kept so any WixUI dialog that does ask
         for an install location still resolves to INSTALL_ROOT.

         ARP* properties (ARPCOMMENTS, ARPCONTACT, ARPURLINFOABOUT)
         were set via CPACK_WIX_PROPERTY_ARP* in the prior CPack-WIX
         config and surface in Add/Remove Programs. They have to be
         declared explicitly now that we own the .wxs. -->
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALL_ROOT" />
    <Property Id="ARPPRODUCTICON">ProductIcon.ico</Property>
    <Property Id="ARPCOMMENTS">Modern Self-hosted game stream host for Moonlight</Property>
    <Property Id="ARPCONTACT">https://github.com/NortheBridge/luminalshine/issues</Property>
    <Property Id="ARPURLINFOABOUT">https://github.com/NortheBridge/luminalshine</Property>
    <Icon Id="ProductIcon.ico" SourceFile="$(var.ProductIcon)" />

    <UIRef Id="WixUI_FeatureTree" />
    <UIRef Id="WixUI_ErrorProgressText" />

    <!--
      ===========================================================
      Properties folded from patch_custom_actions.wxs
      ===========================================================
      ALLUSERS=1 + Privileged condition keep this firmly a
      per-machine install — matched by the requireAdministrator
      manifest on the bootstrapper. Any drift here breaks the
      Reset Admin shortcut's HKCU keypath ICE38/43 compliance
      that's already been hard-won (commits 92c30771 / fe6c73a4).
    -->
    <Property Id="ALLUSERS" Value="1" />
    <Property Id="ARPSYSTEMCOMPONENT" Value="1" />

    <Property Id="LEGACY_SUNSHINE_PRESENT" Secure="yes">
      <RegistrySearch Id="SearchLegacySunshine64" Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\Sunshine" Name="DisplayName" Type="raw" Win64="yes" />
      <RegistrySearch Id="SearchLegacySunshine32" Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\Sunshine" Name="DisplayName" Type="raw" />
    </Property>
    <Property Id="LEGACY_SUNSHINE_UNINSTALL" Secure="yes">
      <RegistrySearch Id="SearchLegacySunshineUninstall64" Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\Sunshine" Name="UninstallString" Type="raw" Win64="yes" />
      <RegistrySearch Id="SearchLegacySunshineUninstall32" Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\Sunshine" Name="UninstallString" Type="raw" />
    </Property>

    <!-- Bootstrapper-contract MSI properties. The bootstrapper passes
         INSTALL_MTTVDD / INSTALL_SUDOVDA / REMOVEVIRTUALDISPLAYDRIVER
         / SKIP_REMOVE_CONFLICTING_PRODUCTS / KEEPADMINCREDENTIALS /
         KEEPSESSIONDATA / DELETEINSTALLDIR on the msiexec command line
         (see RunInstallAttempt in LuminalShineInstaller.cs). Defaults
         here are the values used when the property is unset; the
         bootstrapper overrides per user choice. -->
    <Property Id="REMOVEVIRTUALDISPLAYDRIVER" Value="0" Secure="yes" />
    <Property Id="INSTALL_SUDOVDA" Value="1" Secure="yes" />
    <Property Id="INSTALL_MTTVDD" Value="0" Secure="yes" />
    <Property Id="SKIP_REMOVE_CONFLICTING_PRODUCTS" Value="0" Secure="yes" />

    <Condition Message="Administrator privileges are required.">Privileged</Condition>

    <!--
      ===========================================================
      Directory hierarchy — INSTALL_ROOT chain
      ===========================================================
      Matches what CPack auto-generated from
      CPACK_PACKAGE_INSTALL_DIRECTORY="NortheBridge\LuminalShine":
        TARGETDIR
          ProgramFiles64Folder
            INSTALL_PREFIX_1 (Name=NortheBridge)
              INSTALL_ROOT   (Name=LuminalShine)

      The DefaultDir 8.3 short names in the golden (edtms2sm /
      r0ubect3) are auto-generated by WiX from the long names; using
      the same long names here reproduces them deterministically.

      ProgramMenuFolder + LUMINALSHINE_PROGRAM_MENU_FOLDER are
      declared by custom_actions.wxs, which extends TARGETDIR via a
      DirectoryRef. Do NOT re-declare them here (would be a duplicate
      element error in candle).
    -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALL_PREFIX_1" Name="NortheBridge">
          <Directory Id="INSTALL_ROOT" Name="LuminalShine" />
        </Directory>
      </Directory>
    </Directory>

    <!--
      ===========================================================
      Feature hierarchy
      ===========================================================
      The ProductFeature root + per-install-component CM_C_* and
      per-group CM_G_* features are emitted by gen_wix_files.py
      into <build>/wix_gen/features.wxs from
      packaging/windows/wix/features.json. We pull them in here
      via a single FeatureGroupRef — actually just leave the
      cross-fragment Feature definitions to be linked by light,
      which traces ComponentRef back to its containing Feature
      automatically.

      The LuminalShineExtras feature stays hand-authored here
      because its ComponentRefs target hand-authored Components
      from custom_actions.wxs that are out of the auto-generator's
      scope (services, shortcuts, env, firewall, ARP, sudovda regs).
    -->
    <FeatureRef Id="ProductFeature" />

    <Feature Id="LuminalShineExtras" Title="LuminalShine Components" Level="1" Absent="disallow">
      <ComponentRef Id="CtlStopSunshine" />
      <ComponentRef Id="SunshineSvc" />
      <ComponentRef Id="LuminalShineXboxBtHelperSvc" />
      <ComponentRef Id="LuminalShineSessionMonSvc" />
      <ComponentRef Id="Env_Path" />
      <ComponentRef Id="Fw_Exceptions" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="ReconfigureStartMenuShortcut" />
      <ComponentRef Id="ResetAdminStartMenuShortcut" />
      <ComponentRef Id="SudoVdaRegistryDefaults" />
      <ComponentRef Id="ArpCustomUninstallEntry" />
    </Feature>

    <!--
      Feature-level Conditions for the virtual-display drivers live in
      packaging/windows/wix/features.json (each component spec carries
      an optional `conditions` field). The generator (gen_wix_files.py)
      writes them as <Condition Level="N">expression</Condition>
      children of the corresponding <Feature> in features.wxs.

      An earlier draft tried to add them here via
      <FeatureRef Id="CM_C_mttvdd"><Condition>...</Condition></FeatureRef>
      to mirror the CPackWiXFragment patch mechanism — WiX 3.14's
      candle rejects that with CNDL0005 ("The FeatureRef element
      contains an unexpected child element 'Condition'"). The native
      WiX 3 placement is inside the Feature itself, hence the move
      into the generator+manifest.
    -->

    <!--
      ===========================================================
      InstallExecuteSequence — folded verbatim from
      patch_custom_actions.wxs. The conditions and ordering are
      the production-load-bearing fix shipped in 9d590a6c — keep
      every clause exactly as-is. The lint
      scripts/lint_wix_conditions.py enforces these conditions in
      CI and will reject silent drift.
      ===========================================================
    -->
    <InstallExecuteSequence>
      <!-- Remove conflicting products before installation starts. -->
      <Custom Action="RemoveConflictingProducts" After="InstallInitialize">NOT Installed AND NOT REMOVE AND SKIP_REMOVE_CONFLICTING_PRODUCTS &lt;&gt; "1"</Custom>

      <!-- Pre-validate stop/kill: fire across ALL UI levels (including the
           interactive full-UI install path). WIX_UPGRADE_DETECTED covers
           the install pass of a major upgrade — see the lengthy comment
           in patch_custom_actions.wxs (commit 9d590a6c) for why this
           condition shape is non-negotiable. -->
      <Custom Action="SetKillProcsQuietImmediate" Before="InstallValidate">WIX_UPGRADE_DETECTED OR (Installed AND NOT REMOVE) OR (REMOVE = "ALL" AND NOT UPGRADINGPRODUCTCODE)</Custom>
      <Custom Action="KillProcsQuietImmediate" After="SetKillProcsQuietImmediate">WIX_UPGRADE_DETECTED OR (Installed AND NOT REMOVE) OR (REMOVE = "ALL" AND NOT UPGRADINGPRODUCTCODE)</Custom>
      <Custom Action="SetStopSvcQuietImmediate" After="KillProcsQuietImmediate">WIX_UPGRADE_DETECTED OR (Installed AND NOT REMOVE) OR (REMOVE = "ALL" AND NOT UPGRADINGPRODUCTCODE)</Custom>
      <Custom Action="StopSvcQuietImmediate" After="SetStopSvcQuietImmediate">WIX_UPGRADE_DETECTED OR (Installed AND NOT REMOVE) OR (REMOVE = "ALL" AND NOT UPGRADINGPRODUCTCODE)</Custom>

      <!-- Deferred stop -->
      <Custom Action="SetStopSvcQuiet" After="InstallInitialize">WIX_UPGRADE_DETECTED OR (Installed AND NOT REMOVE) OR (REMOVE = "ALL" AND NOT UPGRADINGPRODUCTCODE)</Custom>
      <Custom Action="StopSvcQuiet" After="SetStopSvcQuiet">WIX_UPGRADE_DETECTED OR (Installed AND NOT REMOVE) OR (REMOVE = "ALL" AND NOT UPGRADINGPRODUCTCODE)</Custom>

      <!-- Start quietly on repair with basic/silent UI -->
      <Custom Action="SetStartSvcQuiet" Before="InstallFinalize">Installed AND NOT REMOVE AND UILevel &lt; 5</Custom>
      <Custom Action="StartSvcQuiet" Before="InstallFinalize">Installed AND NOT REMOVE AND UILevel &lt; 5</Custom>

      <!-- Manual uninstall: process/legacy service cleanup -->
      <Custom Action="SetKillProcsQuiet" After="StopSvcQuiet">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>
      <Custom Action="KillProcsQuiet" After="SetKillProcsQuiet">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>
      <Custom Action="SetRemoveServiceQuiet" After="KillProcsQuiet">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>
      <Custom Action="RemoveServiceQuiet" After="SetRemoveServiceQuiet">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>

      <!-- Post-install chores -->
      <Custom Action="SetResetAcls" After="InstallFiles">NOT REMOVE</Custom>
      <Custom Action="ResetAcls" After="SetResetAcls">NOT REMOVE</Custom>
      <!-- Belt-and-suspenders: AND feature action state (=3 -> INSTALLSTATE_LOCAL)
           with the property switch so we never invoke install.ps1 against
           files that weren't staged, even if the feature condition above
           ever drifts out of sync with the INSTALL_* properties. -->
      <Custom Action="SetInstallMttVdd" After="ResetAcls">NOT REMOVE AND INSTALL_MTTVDD = "1" AND &amp;CM_C_mttvdd=3</Custom>
      <Custom Action="InstallMttVdd" After="SetInstallMttVdd">NOT REMOVE AND INSTALL_MTTVDD = "1" AND &amp;CM_C_mttvdd=3</Custom>
      <Custom Action="SetInstallSudovda" After="InstallMttVdd">NOT REMOVE AND INSTALL_SUDOVDA = "1" AND &amp;CM_C_sudovda=3</Custom>
      <Custom Action="InstallSudovda" After="SetInstallSudovda">NOT REMOVE AND INSTALL_SUDOVDA = "1" AND &amp;CM_C_sudovda=3</Custom>
      <Custom Action="SetMigrateConfig" After="InstallSudovda">NOT REMOVE</Custom>
      <Custom Action="MigrateConfig" After="SetMigrateConfig">NOT REMOVE</Custom>
      <Custom Action="SetRunInstallerMigrations" After="MigrateConfig">NOT REMOVE</Custom>
      <Custom Action="RunInstallerMigrations" After="SetRunInstallerMigrations">NOT REMOVE</Custom>

      <!-- Uninstall before file removal -->
      <Custom Action="SetRestoreNvPrefsUndo" Before="RemoveFiles">REMOVE="ALL"</Custom>
      <Custom Action="RestoreNvPrefsUndo" After="SetRestoreNvPrefsUndo">REMOVE="ALL"</Custom>

      <!-- Clear admin credentials on a real uninstall (skipped during upgrades). -->
      <Custom Action="SetResetAdminCredentials" After="RestoreNvPrefsUndo">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE AND KEEPADMINCREDENTIALS &lt;&gt; "1"</Custom>
      <Custom Action="ResetAdminCredentials" After="SetResetAdminCredentials">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE AND KEEPADMINCREDENTIALS &lt;&gt; "1"</Custom>

      <!-- Wipe session telemetry on a real uninstall (skipped during upgrades). -->
      <Custom Action="SetResetSessionHistory" After="ResetAdminCredentials">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE AND KEEPSESSIONDATA &lt;&gt; "1"</Custom>
      <Custom Action="ResetSessionHistory" After="SetResetSessionHistory">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE AND KEEPSESSIONDATA &lt;&gt; "1"</Custom>

      <!-- Remove Virtual Display Drivers only when explicitly requested. -->
      <Custom Action="SetUninstallMttVdd" After="RestoreNvPrefsUndo">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE AND REMOVEVIRTUALDISPLAYDRIVER = "1"</Custom>
      <Custom Action="UninstallMttVdd" After="SetUninstallMttVdd">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE AND REMOVEVIRTUALDISPLAYDRIVER = "1"</Custom>
      <Custom Action="SetUninstallSudovda" After="UninstallMttVdd">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE AND REMOVEVIRTUALDISPLAYDRIVER = "1"</Custom>
      <Custom Action="UninstallSudovda" After="SetUninstallSudovda">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE AND REMOVEVIRTUALDISPLAYDRIVER = "1"</Custom>

      <!-- Execute delete/prune after MSI removes its files -->
      <Custom Action="SetDeleteInstallDir" After="RemoveFiles">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE AND DELETEINSTALLDIR = "1"</Custom>
      <Custom Action="DeleteInstallDir" After="SetDeleteInstallDir">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE AND DELETEINSTALLDIR = "1"</Custom>

      <!-- If not deleting whole dir, prune everything but config -->
      <Custom Action="SetPruneButConfig" After="RemoveFiles">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE AND DELETEINSTALLDIR &lt;&gt; "1"</Custom>
      <Custom Action="PruneButConfig" After="SetPruneButConfig">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE AND DELETEINSTALLDIR &lt;&gt; "1"</Custom>
    </InstallExecuteSequence>

    <!--
      InstallUISequence — legacy Sunshine pre-uninstall flow +
      repair-complete prompt. Folded verbatim.
    -->
    <!-- Note on condition whitespace: the golden's UILevel comparisons
         have NO surrounding spaces (e.g. UILevel>2 not UILevel > 2).
         Whatever the CPack-WIX path did normalized them out of the
         original "UILevel &gt; 2" source; this path doesn't, so match
         the golden by writing them without spaces directly. -->
    <InstallUISequence>
      <Custom Action="AskUninstallLegacySunshine" After="AppSearch">LEGACY_SUNSHINE_PRESENT AND UILevel&gt;2 AND NOT Installed</Custom>
      <Custom Action="WaitForLegacyUninstall" After="AskUninstallLegacySunshine">UNINSTALL_LEGACY_SUNSHINE = "1" AND NOT USER_CANCELLED_LEGACY_UNINSTALL</Custom>
      <Custom Action="BlockUserCancelledLegacy" Before="LaunchConditions">USER_CANCELLED_LEGACY_UNINSTALL = "1"</Custom>
      <Custom Action="BlockLegacySunshineStillPresent" Before="LaunchConditions">LEGACY_SUNSHINE_STILL_PRESENT = "1"</Custom>
      <Custom Action="RepairCompletePrompt" After="ExecuteAction">REINSTALL AND NOT REMOVE AND NOT UPGRADINGPRODUCTCODE AND UILevel&gt;2</Custom>
    </InstallUISequence>

  </Product>
</Wix>
